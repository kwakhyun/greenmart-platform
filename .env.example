# ============================================================
# GreenMart Platform - 환경 변수 설정
# ============================================================
# 이 파일을 .env 로 복사한 뒤, 실제 값을 입력하세요.
# cp .env.example .env

# ── API 서버 ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ── 프론트엔드 (Next.js) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
